:80 {
	root * /srv
	encode zstd gzip

	@static {
		path_regexp static \
		\.(?:css|js|mjs|png|jpg|jpeg|gif|svg|webp|avif|woff2?|ttf|eot|otf)$
	}
	header @static Cache-Control "public, max-age=31536000, immutable"

	@html {
		path *.html
	}
	header @html Cache-Control "no-cache, must-revalidate"

	file_server

	handle_errors {
		rewrite * /404.html
		file_server
	}
}
