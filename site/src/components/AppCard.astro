---
import ResponsivePicture from "./ResponsivePicture.astro";
import type { AppInfo } from "../data/apps";

type Props = {
  app: AppInfo;
  index?: number;
};

const { app, index = 0 } = Astro.props;

type Hue = "red" | "green" | "blue";

const hueForAccent: Record<string, Hue> = {
  "#ec2f3b": "red",
  "#1f8a70": "green",
  "#3867d6": "blue"
};

const hue: Hue = hueForAccent[app.accent] ?? "red";
---

<a
  class="app-card glass sheen"
  href={`/${app.slug}`}
  data-hue={hue}
  data-reveal
  style={`--i: ${index}; --app-accent: ${app.accent}; --app-accent-text: var(--accent-${hue}-text)`}
  aria-label={`View ${app.name}`}
>
  <div class="app-card-media">
    <ResponsivePicture
      src={app.preview}
      alt={`${app.name} app preview`}
      imageClass="app-card-preview"
      widths={[360, 540, 720, 960]}
      sizes="(max-width: 760px) 92vw, 380px"
      fit="cover"
    />
  </div>
  <div class="app-card-body">
    <span class="app-card-status">
      <span class="app-card-dot" aria-hidden="true"></span>
      {app.statusLabel}
    </span>
    <h3 class="app-card-name">{app.name}</h3>
    <p class="app-card-summary">{app.summary}</p>
    <span class="app-card-cta">
      Open app page
      <span class="app-card-arrow" aria-hidden="true">→</span>
    </span>
  </div>
</a>

<style>
  .app-card {
    display: block;
    padding: 0;
    border-radius: var(--r-lg);
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    transition:
      transform var(--dur-slow) var(--ease-out),
      box-shadow var(--dur-slow) var(--ease-out);
  }

  .app-card:focus-visible {
    outline: 2px solid var(--accent-blue-text);
    outline-offset: 3px;
  }

  .app-card-media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .app-card-media :global(picture) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .app-card-media :global(img.app-card-preview) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-slow) var(--ease-out);
  }

  .app-card-body {
    padding: 24px;
  }

  .app-card-status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border-radius: var(--r-pill);
    background: color-mix(in srgb, var(--app-accent) 14%, transparent);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    color: var(--app-accent-text);
  }

  .app-card-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--app-accent-text);
  }

  .app-card-name {
    margin: 14px 0 0;
    font-size: var(--text-xl);
    font-weight: 650;
    letter-spacing: var(--track-title);
    line-height: 1.15;
    color: var(--text-1);
  }

  .app-card-summary {
    margin: 10px 0 0;
    font-size: var(--text-base);
    letter-spacing: var(--track-body);
    color: var(--text-2);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .app-card-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 18px;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-1);
  }

  .app-card-arrow {
    display: inline-block;
    transition: transform 150ms var(--ease-spring);
  }

  @media (hover: hover) {
    .app-card:hover,
    .app-card:focus-visible {
      transform: translateY(-4px);
      box-shadow: var(--glass-edge), var(--glass-shadow-hover);
    }

    .app-card:hover :global(img.app-card-preview),
    .app-card:focus-visible :global(img.app-card-preview) {
      transform: scale(1.03);
    }

    .app-card:hover .app-card-arrow,
    .app-card:focus-visible .app-card-arrow {
      transform: translateX(3px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .app-card,
    .app-card-media :global(img.app-card-preview),
    .app-card-arrow {
      transition: none;
    }
  }
</style>
