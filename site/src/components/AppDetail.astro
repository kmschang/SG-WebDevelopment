---
import BaseLayout from "../layouts/BaseLayout.astro";
import DownloadLink from "./DownloadLink.astro";
import ResponsivePicture from "./ResponsivePicture.astro";
import { appleDisclaimer } from "../data/siteContent";
import { getLatestReleaseForApp, getReleasesForApp, type AppInfo } from "../data/apps";

type Props = {
  app: AppInfo;
  canonicalPath: string;
};

const { app, canonicalPath } = Astro.props;
const releases = getReleasesForApp(app);
const latestRelease = getLatestReleaseForApp(app);

type Hue = "red" | "green" | "blue";

const hueForAccent: Record<string, Hue> = {
  "#ec2f3b": "red",
  "#1f8a70": "green",
  "#3867d6": "blue"
};

const hue: Hue = hueForAccent[app.accent] ?? "red";
---

<BaseLayout
  title={`${app.name} | Sonnaz Group`}
  description={app.summary}
  canonicalPath={canonicalPath}
  ambient={hue}
>
  <main style={`--app-accent: ${app.accent}; --app-accent-text: var(--accent-${hue}-text)`}>
    <section class="app-hero">
      <ResponsivePicture
        src={app.hero}
        alt={`${app.name} app screen`}
        pictureClass="app-hero-media"
        imageClass="app-hero-image"
        widths={[960, 1280, 1600, 1920]}
        sizes="100vw"
        priority
        fit="cover"
        position="center"
      />
      <div class="app-hero-scrim" aria-hidden="true"></div>
      <div class="container app-hero-content">
        <ResponsivePicture
          src={app.logo}
          alt=""
          imageClass="app-hero-logo"
          widths={[96, 192, 288]}
          sizes="96px"
          loading="eager"
        />
        <p class="eyebrow">{app.eyebrow}</p>
        <h1 class="display">{app.name}</h1>
        <p class="app-hero-description">{app.description}</p>
        <div class="app-hero-actions">
          <a class="pill pill--primary" href="#download">Download</a>
          <a class="pill pill--glass" href="#features">Explore features</a>
          {app.links.map((link) => <a class="pill pill--glass" href={link.href}>{link.label}</a>)}
        </div>
      </div>
    </section>

    <section id="features" class="app-features">
      <div class="container">
        <div class="app-features-heading" data-reveal>
          <p class="eyebrow">Features</p>
          <h2 class="headline">Swipe through the parts people actually use.</h2>
        </div>

        <div
          class="carousel"
          data-feature-carousel
          role="region"
          aria-roledescription="carousel"
          aria-label={`${app.name} features`}
          data-reveal
          style="--i: 1"
        >
          <div class="carousel-mat glass">
            <div class="carousel-viewport" data-carousel-viewport>
              <div class="carousel-track" data-carousel-track aria-live="polite">
                {app.features.map((feature, index) => (
                  <article
                    class:list={["carousel-slide", index === 0 && "is-active"]}
                    data-carousel-slide
                    aria-hidden={index === 0 ? "false" : "true"}
                  >
                    <div class="carousel-media">
                      <div class="carousel-glow" aria-hidden="true"></div>
                      <ResponsivePicture
                        src={feature.image}
                        alt={`${app.name} ${feature.title}`}
                        pictureClass="carousel-picture"
                        imageClass="carousel-image"
                        widths={[360, 540, 720, 960]}
                        sizes="(max-width: 900px) 80vw, 420px"
                        fit="contain"
                      />
                    </div>
                    <div class="carousel-copy">
                      <p class="eyebrow">Feature {index + 1} of {app.features.length}</p>
                      <h3 class="carousel-title">{feature.title}</h3>
                      <p class="carousel-body">{feature.body}</p>
                    </div>
                  </article>
                ))}
              </div>
            </div>

            <button
              class="carousel-button carousel-button-prev glass--flat"
              type="button"
              data-carousel-prev
              aria-label="Previous feature"
            >
              <span aria-hidden="true">‹</span>
            </button>
            <button
              class="carousel-button carousel-button-next glass--flat"
              type="button"
              data-carousel-next
              aria-label="Next feature"
            >
              <span aria-hidden="true">›</span>
            </button>
          </div>

          <div class="carousel-dots-wrap">
            <div class="carousel-dots glass--flat" role="group" aria-label={`${app.name} feature navigation`}>
              {app.features.map((feature, index) => (
                <button
                  class:list={["carousel-dot", index === 0 && "is-active"]}
                  type="button"
                  data-carousel-dot
                  aria-label={`Show ${feature.title}`}
                  aria-current={index === 0 ? "true" : "false"}
                ></button>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="download" class="app-download">
      <div class="container">
        <div class="app-download-heading" data-reveal>
          <p class="eyebrow">Download</p>
          <h2 class="headline">Get {app.name}.</h2>
          <p class="app-download-note">{app.availabilityNote}</p>
        </div>

        <div class="app-download-grid">
          <article class="app-panel glass sheen" data-reveal style="--i: 1">
            <p class="eyebrow">Official links</p>
            <div class="download-stack">
              {app.downloads.map((download) => <DownloadLink download={download} />)}
            </div>
            <p class="legal-note">{appleDisclaimer}</p>
            <div class="panel-hairline" aria-hidden="true"></div>
            <p class="eyebrow">App information</p>
            <dl class="info-list">
              <div class="info-row">
                <dt>Release date</dt>
                <dd>{latestRelease?.date ?? app.plannedRelease?.date ?? "—"}</dd>
              </div>
              <div class="info-row">
                <dt>Version</dt>
                <dd>{latestRelease?.version ?? app.plannedRelease?.version ?? "—"}</dd>
              </div>
              <div class="info-row">
                <dt>Size</dt>
                <dd>{app.appInfo.size}</dd>
              </div>
              <div class="info-row">
                <dt>Languages</dt>
                <dd>{app.appInfo.languages}</dd>
              </div>
              <div class="info-row">
                <dt>Developer</dt>
                <dd>{app.appInfo.developer}</dd>
              </div>
            </dl>
          </article>

          <div class="app-download-side">
            <article class="app-panel glass sheen" data-reveal style="--i: 2">
              <p class="eyebrow">Release notes</p>
              <div class="release-list">
                {releases.length > 0 ? (
                  releases.slice(0, 2).map((release) => (
                    <section class="release-entry">
                      <header class="release-header">
                        <h3 class="release-version">{release.version}</h3>
                        <span class="release-date">{release.date}</span>
                      </header>
                      <ul class="release-bullets">
                        {release.bullets.map((bullet) => <li>{bullet}</li>)}
                      </ul>
                    </section>
                  ))
                ) : (
                  <p class="release-empty">Release notes will appear here when this app is public.</p>
                )}
              </div>
            </article>

            <a class="press-tile glass--flat" href={app.pressKitHref} download data-reveal style="--i: 3">
              <ResponsivePicture
                src={app.logo}
                alt=""
                imageClass="press-logo"
                widths={[42, 84, 126]}
                sizes="42px"
              />
              <span class="press-label">Download press kit</span>
              <span class="press-arrow" aria-hidden="true">↓</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <style>
    /* ---------- Hero ---------- */

    .app-hero {
      position: relative;
      min-height: 92svh;
      display: flex;
      align-items: flex-end;
      overflow: hidden;
    }

    .app-hero :global(.app-hero-media) {
      position: absolute;
      inset: 0;
    }

    .app-hero :global(img.app-hero-image) {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .app-hero-scrim {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(
          900px 500px at 50% 0%,
          color-mix(in srgb, var(--app-accent) 22%, transparent),
          transparent 65%
        ),
        linear-gradient(180deg, rgba(5, 6, 10, 0.55) 0%, rgba(5, 6, 10, 0.78) 55%, #05060a 100%);
    }

    .app-hero-content {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding-top: calc(var(--header-h) + 48px);
      padding-bottom: 96px;
    }

    .app-hero :global(img.app-hero-logo) {
      width: 96px;
      height: 96px;
      border-radius: var(--r-md);
      box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.14),
        0 24px 48px -20px rgba(0, 0, 0, 0.7);
    }

    .app-hero-content .eyebrow {
      margin: 26px 0 0;
    }

    .app-hero-content h1 {
      margin-top: 10px;
    }

    .app-hero-description {
      margin: 18px auto 0;
      max-width: 60ch;
      font-size: var(--text-lg);
      letter-spacing: var(--track-body);
      color: var(--text-2);
    }

    .app-hero-actions {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 12px;
      margin-top: 30px;
    }

    /* Load choreography: staggered settle-in once the page is loaded. */
    :global(html.js) .app-hero-content > :global(*) {
      opacity: 0;
      transform: translateY(24px);
      transition:
        opacity var(--dur-reveal) var(--ease-out),
        transform var(--dur-reveal) var(--ease-out);
    }

    :global(html.js) .app-hero-content > :global(*:nth-child(2)) {
      transition-delay: 80ms;
    }

    :global(html.js) .app-hero-content > :global(*:nth-child(3)) {
      transition-delay: 160ms;
    }

    :global(html.js) .app-hero-content > :global(*:nth-child(4)) {
      transition-delay: 240ms;
    }

    :global(html.js) .app-hero-content > :global(*:nth-child(5)) {
      transition-delay: 320ms;
    }

    :global(html.js body.is-loaded) .app-hero-content > :global(*) {
      opacity: 1;
      transform: none;
    }

    /* ---------- Features carousel ---------- */

    .app-features .container {
      padding-top: var(--section-gap);
    }

    .app-features-heading {
      max-width: 40ch;
      margin-bottom: 36px;
    }

    .app-features-heading .headline {
      margin-top: 10px;
    }

    .carousel-mat {
      padding: 10px;
      border-radius: var(--r-lg);
    }

    .carousel-viewport {
      overflow: hidden;
      border-radius: calc(var(--r-lg) - 10px);
    }

    .carousel-track {
      display: flex;
      transition: transform var(--dur-slow) var(--ease-sheet);
    }

    .carousel-slide {
      flex: 0 0 100%;
      min-width: 100%;
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      gap: clamp(24px, 4vw, 48px);
      padding: clamp(24px, 4vw, 48px);
    }

    .carousel-media {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 240px;
    }

    .carousel-glow {
      position: absolute;
      inset: 8%;
      background: radial-gradient(
        closest-side,
        color-mix(in srgb, var(--app-accent) 26%, transparent),
        transparent 72%
      );
    }

    .carousel-media :global(.carousel-picture) {
      position: relative;
      z-index: 1;
      display: flex;
      justify-content: center;
      max-width: 100%;
    }

    .carousel-media :global(img.carousel-image) {
      display: block;
      max-height: 540px;
      width: auto;
      max-width: 100%;
      height: auto;
      object-fit: contain;
      filter: drop-shadow(0 32px 48px rgba(0, 0, 0, 0.55));
    }

    .carousel-copy {
      align-self: center;
    }

    .carousel-title {
      margin: 12px 0 0;
      font-size: var(--text-xl);
      font-weight: 650;
      letter-spacing: var(--track-title);
      color: var(--text-1);
    }

    .carousel-body {
      margin: 12px 0 0;
      font-size: var(--text-base);
      letter-spacing: var(--track-body);
      color: var(--text-2);
      max-width: 46ch;
    }

    .carousel-slide .carousel-media,
    .carousel-slide .carousel-copy {
      opacity: 0.35;
      transform: translateY(8px);
      transition:
        opacity var(--dur-base) var(--ease-out),
        transform var(--dur-base) var(--ease-out);
    }

    .carousel-slide.is-active .carousel-media {
      opacity: 1;
      transform: none;
      transition-delay: 80ms;
    }

    .carousel-slide.is-active .carousel-copy {
      opacity: 1;
      transform: none;
      transition-delay: 150ms;
    }

    .carousel-button {
      position: absolute;
      top: 50%;
      z-index: 2;
      width: 44px;
      height: 44px;
      padding: 0;
      border-radius: 50%;
      display: grid;
      place-items: center;
      font-size: 22px;
      line-height: 1;
      color: var(--text-1);
      cursor: pointer;
      transform: translateY(-50%);
      transition: transform 150ms var(--ease-spring);
    }

    .carousel-button:hover {
      transform: translateY(-50%) scale(1.08);
    }

    .carousel-button:focus-visible {
      outline: 2px solid var(--accent-blue-text);
      outline-offset: 3px;
    }

    .carousel-button-prev {
      left: 14px;
    }

    .carousel-button-next {
      right: 14px;
    }

    .carousel-dots-wrap {
      display: flex;
      justify-content: center;
      margin-top: 18px;
    }

    .carousel-dots {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 8px 12px;
      border-radius: var(--r-pill);
    }

    .carousel-dot {
      position: relative;
      width: 6px;
      height: 6px;
      padding: 0;
      border: none;
      border-radius: var(--r-pill);
      background: rgba(255, 255, 255, 0.3);
      cursor: pointer;
      transition:
        width var(--dur-base) var(--ease-spring),
        background-color var(--dur-base) var(--ease-spring);
    }

    /* Invisible expanded hit area so 6px dots stay tappable. */
    .carousel-dot::after {
      content: "";
      position: absolute;
      inset: -10px;
    }

    .carousel-dot.is-active {
      width: 20px;
      background: var(--app-accent-text);
    }

    .carousel-dot:focus-visible {
      outline: 2px solid var(--accent-blue-text);
      outline-offset: 3px;
    }

    @media (max-width: 899px) {
      .carousel-slide {
        grid-template-columns: 1fr;
      }

      .carousel-media :global(img.carousel-image) {
        max-height: min(540px, 52vh);
      }

      .carousel-copy {
        text-align: center;
      }

      .carousel-body {
        margin-inline: auto;
      }

      .carousel-button-prev {
        left: 10px;
      }

      .carousel-button-next {
        right: 10px;
      }
    }

    /* ---------- Download bento ---------- */

    .app-download .container {
      padding-block: var(--section-gap);
    }

    .app-download-heading {
      max-width: 62ch;
      margin-bottom: 36px;
    }

    .app-download-heading .headline {
      margin-top: 10px;
    }

    .app-download-note {
      margin: 14px 0 0;
      font-size: var(--text-base);
      letter-spacing: var(--track-body);
      color: var(--text-2);
    }

    .app-download-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      align-items: start;
    }

    .app-panel {
      border-radius: var(--r-lg);
      padding: 28px;
    }

    .download-stack {
      display: grid;
      gap: 12px;
      margin-top: 16px;
    }

    .legal-note {
      margin: 18px 0 0;
      font-size: var(--text-xs);
      color: var(--text-3);
    }

    .panel-hairline {
      height: 1px;
      background: var(--hairline);
      margin: 24px 0;
    }

    .info-list {
      margin: 8px 0 0;
    }

    .info-row {
      display: grid;
      grid-template-columns: auto 1fr;
      align-items: center;
      gap: 16px;
      min-height: 44px;
    }

    .info-row + .info-row {
      border-top: 1px solid var(--hairline);
    }

    .info-row dt {
      font-size: var(--text-sm);
      color: var(--text-3);
    }

    .info-row dd {
      margin: 0;
      font-size: var(--text-base);
      font-weight: 500;
      color: var(--text-1);
      text-align: right;
    }

    .app-download-side {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .release-list {
      display: grid;
      gap: 24px;
      margin-top: 16px;
    }

    .release-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }

    .release-version {
      margin: 0;
      font-size: var(--text-lg);
      font-weight: 650;
      letter-spacing: var(--track-title);
      color: var(--text-1);
    }

    .release-date {
      font-size: var(--text-sm);
      color: var(--text-3);
    }

    .release-bullets {
      margin: 10px 0 0;
      padding-left: 18px;
      display: grid;
      gap: 6px;
      font-size: var(--text-sm);
      letter-spacing: var(--track-body);
      color: var(--text-2);
    }

    .release-empty {
      margin: 0;
      font-size: var(--text-base);
      color: var(--text-2);
    }

    .press-tile {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 14px;
      padding: 20px;
      border-radius: var(--r-md);
      color: var(--text-1);
      text-decoration: none;
    }

    .press-tile :global(img.press-logo) {
      width: 42px;
      height: 42px;
      border-radius: 10px;
    }

    .press-label {
      font-size: var(--text-sm);
      font-weight: 600;
    }

    .press-arrow {
      font-size: var(--text-base);
      color: var(--text-2);
      transition: transform 150ms var(--ease-spring);
    }

    .press-tile:hover .press-arrow {
      transform: translateY(3px);
    }

    .press-tile:focus-visible {
      outline: 2px solid var(--accent-blue-text);
      outline-offset: 3px;
    }

    @media (max-width: 899px) {
      .app-download-grid {
        grid-template-columns: 1fr;
      }
    }

    /* ---------- Reduced motion ---------- */

    @media (prefers-reduced-motion: reduce) {
      :global(html.js) .app-hero-content > :global(*) {
        opacity: 1;
        transform: none;
        transition: none;
      }

      .carousel-track,
      .carousel-slide .carousel-media,
      .carousel-slide .carousel-copy,
      .carousel-button,
      .carousel-dot,
      .press-arrow {
        transition: none;
      }
    }
  </style>

  <script>
    const setupFeatureCarousels = (): void => {
      const reduceMotionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
      const carousels = document.querySelectorAll<HTMLElement>("[data-feature-carousel]");

      carousels.forEach((carousel) => {
        const track = carousel.querySelector<HTMLElement>("[data-carousel-track]");
        const viewport = carousel.querySelector<HTMLElement>("[data-carousel-viewport]");
        const slides = Array.from(carousel.querySelectorAll<HTMLElement>("[data-carousel-slide]"));
        const dots = Array.from(carousel.querySelectorAll<HTMLButtonElement>("[data-carousel-dot]"));
        const prevButton = carousel.querySelector<HTMLButtonElement>("[data-carousel-prev]");
        const nextButton = carousel.querySelector<HTMLButtonElement>("[data-carousel-next]");

        if (!track || slides.length === 0) {
          return;
        }

        const intervalMs = 6000;
        let activeIndex = 0;
        let timer: number | undefined;
        let hoverPaused = false;
        let focusPaused = false;
        let pointerPaused = false;
        let swipeStartX: number | null = null;

        const applyMotionPreference = (): void => {
          track.style.transition = reduceMotionQuery.matches ? "none" : "";
        };

        const autoplayAllowed = (): boolean => !reduceMotionQuery.matches && slides.length > 1;

        const isPaused = (): boolean =>
          hoverPaused || focusPaused || pointerPaused || document.hidden;

        const updateLiveRegion = (): void => {
          track.setAttribute("aria-live", timer !== undefined ? "off" : "polite");
        };

        const stopTimer = (): void => {
          if (timer !== undefined) {
            window.clearInterval(timer);
            timer = undefined;
          }
          updateLiveRegion();
        };

        const setSlide = (index: number): void => {
          activeIndex = (index + slides.length) % slides.length;
          track.style.transform = `translate3d(${activeIndex * -100}%, 0, 0)`;

          slides.forEach((slide, slideIndex) => {
            const isActive = slideIndex === activeIndex;
            slide.classList.toggle("is-active", isActive);
            slide.setAttribute("aria-hidden", isActive ? "false" : "true");
          });

          dots.forEach((dot, dotIndex) => {
            const isActive = dotIndex === activeIndex;
            dot.classList.toggle("is-active", isActive);
            dot.setAttribute("aria-current", isActive ? "true" : "false");
          });
        };

        const startTimer = (): void => {
          if (timer !== undefined) {
            window.clearInterval(timer);
            timer = undefined;
          }

          if (autoplayAllowed() && !isPaused()) {
            timer = window.setInterval(() => {
              setSlide(activeIndex + 1);
            }, intervalMs);
          }
          updateLiveRegion();
        };

        const syncTimer = (): void => {
          if (autoplayAllowed() && !isPaused()) {
            startTimer();
          } else {
            stopTimer();
          }
        };

        prevButton?.addEventListener("click", () => {
          setSlide(activeIndex - 1);
          syncTimer();
        });

        nextButton?.addEventListener("click", () => {
          setSlide(activeIndex + 1);
          syncTimer();
        });

        dots.forEach((dot, dotIndex) => {
          dot.addEventListener("click", () => {
            setSlide(dotIndex);
            syncTimer();
          });
        });

        carousel.addEventListener("pointerenter", () => {
          hoverPaused = true;
          syncTimer();
        });

        carousel.addEventListener("pointerleave", () => {
          hoverPaused = false;
          syncTimer();
        });

        carousel.addEventListener("focusin", () => {
          focusPaused = true;
          syncTimer();
        });

        carousel.addEventListener("focusout", (event: FocusEvent) => {
          const nextTarget = event.relatedTarget;
          if (!(nextTarget instanceof Node) || !carousel.contains(nextTarget)) {
            focusPaused = false;
            syncTimer();
          }
        });

        viewport?.addEventListener("pointerdown", (event: PointerEvent) => {
          swipeStartX = event.clientX;
          pointerPaused = true;
          syncTimer();
        });

        viewport?.addEventListener("pointerup", (event: PointerEvent) => {
          if (swipeStartX !== null) {
            const deltaX = event.clientX - swipeStartX;
            if (Math.abs(deltaX) >= 40) {
              setSlide(deltaX < 0 ? activeIndex + 1 : activeIndex - 1);
            }
          }
          swipeStartX = null;
          pointerPaused = false;
          syncTimer();
        });

        viewport?.addEventListener("pointercancel", () => {
          swipeStartX = null;
          pointerPaused = false;
          syncTimer();
        });

        document.addEventListener("visibilitychange", syncTimer);

        reduceMotionQuery.addEventListener("change", () => {
          applyMotionPreference();
          syncTimer();
        });

        applyMotionPreference();
        setSlide(0);
        syncTimer();
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setupFeatureCarousels, { once: true });
    } else {
      setupFeatureCarousels();
    }
  </script>
</BaseLayout>
