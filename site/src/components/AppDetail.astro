---
import BaseLayout from "../layouts/BaseLayout.astro";
import DownloadLink from "./DownloadLink.astro";
import ResponsivePicture from "./ResponsivePicture.astro";
import { appleDisclaimer } from "../data/siteContent";
import { getLatestReleaseForApp, getReleasesForApp, type AppInfo } from "../data/apps";

type Props = {
  app: AppInfo;
  canonicalPath: string;
};

const { app, canonicalPath } = Astro.props;
const releases = getReleasesForApp(app);
const latestRelease = getLatestReleaseForApp(app);
const getScrubImages = (index: number) => {
  const previous = app.features[(index - 1 + app.features.length) % app.features.length]?.image;
  const current = app.features[index].image;
  const next = app.features[(index + 1) % app.features.length]?.image;

  return [previous, current, next].filter(Boolean);
};
---

<BaseLayout
  title={`${app.name} | Sonnaz Group`}
  description={app.summary}
  canonicalPath={canonicalPath}
>
  <main style={`--app-accent: ${app.accent}`}>
    <section class="product-hero">
      <ResponsivePicture
        src={app.hero}
        alt={`${app.name} app screen`}
        pictureClass="hero-background"
        imageClass="hero-background-image"
        widths={[960, 1280, 1600, 1920]}
        sizes="100vw"
        priority
        fit="cover"
        position="center"
      />
      <div class="hero-scrim"></div>
      <div class="product-hero-content">
        <ResponsivePicture
          src={app.logo}
          alt=""
          imageClass="product-logo"
          widths={[86, 172, 258]}
          sizes="86px"
          loading="eager"
        />
        <p class="eyebrow">{app.eyebrow}</p>
        <h1>{app.name}</h1>
        <p>{app.description}</p>
        <div class="hero-actions">
          <a class="primary-button" href="#download">Download</a>
          <a class="secondary-button" href="#features">Explore features</a>
          {app.links.map((link) => <a class="secondary-button" href={link.href}>{link.label}</a>)}
        </div>
      </div>
    </section>

    <section
      id="features"
      class="feature-carousel-section"
      data-feature-carousel
      aria-label={`${app.name} feature slideshow`}
    >
      <div class="section-heading feature-carousel-heading">
        <p class="eyebrow">Features</p>
        <h2>Swipe through the parts people actually use.</h2>
      </div>

      <div class="feature-carousel">
        <button
          class="feature-carousel-button feature-carousel-prev"
          type="button"
          data-carousel-prev
          aria-label="Previous feature"
        >
          <span aria-hidden="true">‹</span>
        </button>

        <div class="feature-carousel-viewport">
          <div class="feature-carousel-track" data-carousel-track>
            {app.features.map((feature, index) => (
              <article class="feature-slide" data-carousel-slide aria-hidden={index === 0 ? "false" : "true"}>
                <div class="feature-media">
                  <div class="feature-scrub" aria-label={`${app.name} screenshots related to ${feature.title}`}>
                    {getScrubImages(index).map((image, imageIndex) => (
                      <ResponsivePicture
                        src={image}
                        pictureClass={["feature-scrub-image", imageIndex === 1 && "feature-scrub-primary"]
                          .filter(Boolean)
                          .join(" ")}
                        imageClass="feature-scrub-img"
                        alt={imageIndex === 1 ? `${app.name} ${feature.title}` : ""}
                        widths={[360, 540, 720, 960]}
                        sizes="(max-width: 700px) 58vw, 340px"
                        fit="contain"
                      />
                    ))}
                  </div>
                </div>
                <div class="feature-copy">
                  <p class="eyebrow">Feature {index + 1} of {app.features.length}</p>
                  <h2>{feature.title}</h2>
                  <p>{feature.body}</p>
                </div>
              </article>
            ))}
          </div>
        </div>

        <button
          class="feature-carousel-button feature-carousel-next"
          type="button"
          data-carousel-next
          aria-label="Next feature"
        >
          <span aria-hidden="true">›</span>
        </button>

        <div class="feature-dots" aria-label={`${app.name} feature navigation`}>
          {app.features.map((feature, index) => (
            <button
              class:list={["feature-dot", index === 0 && "is-active"]}
              type="button"
              data-carousel-dot
              aria-label={`Show ${feature.title}`}
              aria-current={index === 0 ? "true" : "false"}
            ></button>
          ))}
        </div>
      </div>
    </section>

    <section id="download" class="section app-action-section">
      <div class="section-heading">
        <p class="eyebrow">Download</p>
        <h2>
          Download, version details, and the bits people usually hunt for.
        </h2>
        <p>{app.availabilityNote}</p>
      </div>
      <div class="app-action-grid">
        <article class="glass-panel download-panel">
          <p class="eyebrow">Official links</p>
          <div class="download-grid">
            {app.downloads.map((download) => <DownloadLink download={download} />)}
          </div>
          <p class="legal-note">{appleDisclaimer}</p>
        </article>

        <article class="glass-panel info-panel">
          <p class="eyebrow">App information</p>
          <dl class="info-list">
            <div>
              <dt>Release date</dt>
              <dd>{latestRelease?.date ?? app.plannedRelease?.date ?? "—"}</dd>
            </div>
            <div>
              <dt>Version</dt>
              <dd>{latestRelease?.version ?? app.plannedRelease?.version ?? "—"}</dd>
            </div>
            <div>
              <dt>Size</dt>
              <dd>{app.appInfo.size}</dd>
            </div>
            <div>
              <dt>Languages</dt>
              <dd>{app.appInfo.languages}</dd>
            </div>
            <div>
              <dt>Developer</dt>
              <dd>{app.appInfo.developer}</dd>
            </div>
          </dl>
        </article>

        <article class="glass-panel release-panel">
          <p class="eyebrow">Release notes</p>
          <div class="app-release-list">
            {releases.length > 0 ? (
              releases.slice(0, 2).map((release) => (
                <section>
                  <h3>{release.version}</h3>
                  <small>{release.date}</small>
                  <ul>
                    {release.bullets.map((bullet) => <li>{bullet}</li>)}
                  </ul>
                </section>
              ))
            ) : (
              <p>Release notes will appear here when this app is public.</p>
            )}
          </div>
        </article>

        {app.pressKitHref && (
          <article class="glass-panel press-panel app-press-panel">
            <p class="eyebrow">Press kit</p>
            <h3>{app.name} assets</h3>
            <p>Logos, screenshots, and app artwork for quick reference.</p>
            <a class="app-press-download" href={app.pressKitHref} download>
              <ResponsivePicture src={app.logo} alt="" widths={[36, 72, 108]} sizes="36px" />
              <span>Download press kit</span>
            </a>
          </article>
        )}
      </div>
    </section>
  </main>

  <script>
    const setupFeatureCarousels = () => {
      const carousels = document.querySelectorAll<HTMLElement>("[data-feature-carousel]");

      carousels.forEach((carousel) => {
        const track = carousel.querySelector<HTMLElement>("[data-carousel-track]");
        const slides = Array.from(carousel.querySelectorAll<HTMLElement>("[data-carousel-slide]"));
        const dots = Array.from(carousel.querySelectorAll<HTMLButtonElement>("[data-carousel-dot]"));
        const previous = carousel.querySelector<HTMLButtonElement>("[data-carousel-prev]");
        const next = carousel.querySelector<HTMLButtonElement>("[data-carousel-next]");
        const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const intervalMs = 10000;
        let activeIndex = 0;
        let timer: number | undefined;

        if (!track || slides.length === 0) {
          return;
        }

        const stopTimer = () => {
          if (timer !== undefined) {
            window.clearInterval(timer);
            timer = undefined;
          }
        };

        const startTimer = () => {
          stopTimer();

          if (!prefersReducedMotion && slides.length > 1) {
            timer = window.setInterval(() => {
              setSlide(activeIndex + 1);
            }, intervalMs);
          }
        };

        const setSlide = (index: number) => {
          activeIndex = (index + slides.length) % slides.length;
          carousel.style.setProperty("--feature-slide-index", String(activeIndex));
          carousel.style.setProperty("--feature-slide-offset", `${activeIndex * -100}%`);
          track.style.transform = `translate3d(${activeIndex * -100}%, 0, 0)`;

          slides.forEach((slide, slideIndex) => {
            const isActive = slideIndex === activeIndex;
            slide.classList.toggle("is-active", isActive);
            slide.setAttribute("aria-hidden", isActive ? "false" : "true");
          });

          dots.forEach((dot, dotIndex) => {
            const isActive = dotIndex === activeIndex;
            dot.classList.toggle("is-active", isActive);
            dot.setAttribute("aria-current", isActive ? "true" : "false");
          });
        };

        previous?.addEventListener("click", () => {
          setSlide(activeIndex - 1);
          startTimer();
        });

        next?.addEventListener("click", () => {
          setSlide(activeIndex + 1);
          startTimer();
        });

        dots.forEach((dot, dotIndex) => {
          dot.addEventListener("click", () => {
            setSlide(dotIndex);
            startTimer();
          });
        });

        carousel.addEventListener("mouseenter", stopTimer);
        carousel.addEventListener("mouseleave", startTimer);
        carousel.addEventListener("focusin", stopTimer);
        carousel.addEventListener("focusout", startTimer);

        setSlide(0);
        startTimer();
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setupFeatureCarousels, { once: true });
    } else {
      setupFeatureCarousels();
    }
  </script>
</BaseLayout>
