---
import ResponsivePicture from "./ResponsivePicture.astro";
import logoUrl from "../../../Assets/SonnazGroup/SonnazGroup_Logo(Red)(Transparent).png";

const navItems = [
  { label: "Apps", href: "/#apps" },
  { label: "Pulse", href: "/#pulse" },
  { label: "FAQ", href: "/#faq" },
  { label: "Privacy & Terms", href: "/#privacy-terms" },
  { label: "Feedback", href: "/#contact" }
];
---

<header class="site-header">
  <a class="brand-link" href="/" aria-label="Sonnaz Group home">
    <ResponsivePicture
      src={logoUrl}
      alt=""
      imageClass="brand-mark"
      widths={[38, 76, 114]}
      sizes="38px"
      loading="eager"
    />
    <span>Sonnaz Group</span>
  </a>
  <nav class="site-nav" aria-label="Primary navigation">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
</header>
