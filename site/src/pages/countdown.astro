---
import BaseLayout from "../layouts/BaseLayout.astro";
import DownloadLink from "../components/DownloadLink.astro";
import ResponsivePicture from "../components/ResponsivePicture.astro";
import { getAppBySlug } from "../data/apps";

// This page is the web fallback for shared-countdown Universal Links
// (https://sonnazgroup.com/countdown?d=...). On a device with the app
// installed, iOS opens the countdown directly and never loads this page.
// Everyone else lands here, so point them at the App Store.
const app = getAppBySlug("day-tracker");
const appStore = app.downloads.find((download) => download.kind === "app-store");
---

<BaseLayout
  title={`Open shared countdown | ${app.name}`}
  description={`Someone shared a countdown with you. Get ${app.name} to open it on your iPhone.`}
  canonicalPath="/countdown"
  noindex={true}
>
  <main style={`--app-accent: ${app.accent}`}>
    <section class="product-hero countdown-hero">
      <ResponsivePicture
        src={app.hero}
        alt={`${app.name} app screen`}
        pictureClass="hero-background"
        imageClass="hero-background-image"
        widths={[960, 1280, 1600, 1920]}
        sizes="100vw"
        priority
        fit="cover"
        position="center"
      />
      <div class="hero-scrim"></div>
      <div class="product-hero-content countdown-content">
        <ResponsivePicture
          src={app.logo}
          alt=""
          imageClass="product-logo"
          widths={[86, 172, 258]}
          sizes="86px"
          loading="eager"
        />
        <p class="eyebrow">Shared countdown</p>
        <h1>Someone shared a countdown</h1>
        <p>
          This link opens in {app.name} on iPhone. If you already have the app, tap
          the link again and it jumps straight to the countdown. If not, download {app.name}
          first, then reopen the link to import it.
        </p>
        {
          appStore && (
            <div class="countdown-cta">
              <DownloadLink download={appStore} />
              <a class="text-link" href="/day-tracker">
                Learn more about {app.name} &rarr;
              </a>
            </div>
          )
        }
      </div>
    </section>
  </main>

  <style>
    /* Compact, single-screen landing — shorter than the full product hero,
       smaller headline so it never clips under the sticky header, and one CTA. */
    .countdown-hero {
      min-height: clamp(34rem, 78svh, 44rem);
      padding-block: clamp(4.5rem, 10vw, 7rem);
    }

    .countdown-hero h1 {
      font-size: clamp(2.4rem, 6vw, 3.6rem);
      line-height: 1.05;
    }

    .countdown-content > p {
      max-width: 52ch;
    }

    .countdown-cta {
      display: grid;
      gap: 0.9rem;
      justify-items: start;
      margin-top: 1.8rem;
    }

    .countdown-cta .download-link {
      width: min(360px, 100%);
    }

    .countdown-cta .text-link {
      margin-top: 0;
    }
  </style>
</BaseLayout>
