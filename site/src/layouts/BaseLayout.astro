---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.scss";
import faviconUrl from "../../../Assets/favicon.png?url";

type Props = {
  title?: string;
  description?: string;
  canonicalPath?: string;
  canonicalOverride?: string;
  noindex?: boolean;
  ambient?: "red" | "green" | "blue";
};

const {
  title = "Sonnaz Group",
  description = "Sonnaz Group builds practical software for everyday tasks.",
  canonicalPath = "/",
  canonicalOverride,
  noindex = false,
  ambient
} = Astro.props;

// When set, `canonicalOverride` is emitted verbatim as the canonical + og:url.
// The shared-countdown page uses it to carry a Caddy template token so the live
// server can stamp the real request URL (with the ?d= payload) into og:url —
// see site/Caddyfile. Rich-link previewers (iMessage) adopt og:url as the
// tappable link, so it must reflect the incoming URL or the payload is stripped.
const canonicalUrl = canonicalOverride ?? new URL(canonicalPath, "https://sonnazgroup.com").toString();
const deployEnvironment = (import.meta.env.PUBLIC_DEPLOY_ENV ?? "").toLowerCase();
const isStaging = deployEnvironment === "staging";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#05060a" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href={faviconUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <title>{title}</title>
    <script is:inline>document.documentElement.classList.add("js");</script>
  </head>
  <body class={isStaging ? "is-staging" : undefined} data-ambient={ambient}>
    {isStaging && <div class="staging-marker" role="note" aria-label="Staging environment">Staging</div>}
    <div class="ambient" aria-hidden="true">
      <div class="ambient__base"></div>
      <div class="ambient__red"></div>
      <div class="ambient__green"></div>
      <div class="ambient__blue"></div>
      <div class="ambient__noise"></div>
    </div>
    <Header />
    <slot />
    <Footer />
    <script>
      // ----------------------------------------------------------------------
      // Global interaction runtime: load choreography, settle-in reveals,
      // cursor sheen, ambient hue manager. Pages must NOT re-implement these.
      // ----------------------------------------------------------------------

      // Settle-in reveals -----------------------------------------------------
      const revealTargets: HTMLElement[] = Array.from(
        document.querySelectorAll<HTMLElement>("[data-reveal]")
      );

      const revealAll = (): void => {
        for (const el of revealTargets) el.classList.add("is-in");
      };

      // Reduced motion: checked once, tracked on change.
      const reduceQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
      let reduceMotion = reduceQuery.matches;
      reduceQuery.addEventListener("change", (event: MediaQueryListEvent) => {
        reduceMotion = event.matches;
        if (reduceMotion) revealAll();
      });

      // Load choreography: pages key entrances off html.js + body.is-loaded.
      const markLoaded = (): void => {
        document.body.classList.add("is-loaded");
      };
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", markLoaded, { once: true });
      } else {
        markLoaded();
      }

      if (reduceMotion || !("IntersectionObserver" in window)) {
        revealAll();
      } else {
        const io = new IntersectionObserver(
          (entries, observer) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-in");
                observer.unobserve(entry.target);
              }
            }
          },
          { rootMargin: "0px 0px -12% 0px", threshold: 0.1 }
        );
        for (const el of revealTargets) io.observe(el);
      }

      // Cursor sheen ----------------------------------------------------------
      // Single delegated, rAF-throttled listener; desktop pointers only.
      const finePointer = window.matchMedia("(hover: hover) and (pointer: fine)");
      let sheenFrame: number | null = null;
      let sheenX = 0;
      let sheenY = 0;
      let sheenTarget: Element | null = null;

      document.addEventListener(
        "pointermove",
        (event: PointerEvent) => {
          if (reduceMotion || !finePointer.matches) return;
          sheenX = event.clientX;
          sheenY = event.clientY;
          sheenTarget = event.target instanceof Element ? event.target : null;
          if (sheenFrame !== null) return;
          sheenFrame = window.requestAnimationFrame(() => {
            sheenFrame = null;
            const host = sheenTarget ? sheenTarget.closest<HTMLElement>(".sheen") : null;
            if (!host) return;
            const rect = host.getBoundingClientRect();
            if (rect.width === 0 || rect.height === 0) return;
            const mx = ((sheenX - rect.left) / rect.width) * 100;
            const my = ((sheenY - rect.top) / rect.height) * 100;
            host.style.setProperty("--mx", `${mx.toFixed(2)}%`);
            host.style.setProperty("--my", `${my.toFixed(2)}%`);
          });
        },
        { passive: true }
      );

      // Ambient hue manager ---------------------------------------------------
      // Hovering/focusing a [data-hue] element crossfades the fixed background
      // wash to that hue. Inline opacity is used ONLY for hover overrides and
      // is fully cleared on revert so the CSS body[data-ambient] rule (or the
      // neutral base) wins again.
      type Hue = "red" | "green" | "blue";
      const hueNames: readonly Hue[] = ["red", "green", "blue"];
      const hueLayers = new Map<Hue, HTMLElement>();
      for (const hue of hueNames) {
        const layer = document.querySelector<HTMLElement>(`.ambient__${hue}`);
        if (layer) hueLayers.set(hue, layer);
      }

      const isHue = (value: string): value is Hue =>
        value === "red" || value === "green" || value === "blue";

      const applyHueOverride = (hue: Hue): void => {
        if (reduceMotion) return;
        for (const [name, layer] of hueLayers) {
          layer.style.opacity = name === hue ? "1" : "0";
        }
      };

      const clearHueOverride = (): void => {
        for (const layer of hueLayers.values()) {
          layer.style.removeProperty("opacity");
        }
      };

      const hueElements: HTMLElement[] = Array.from(
        document.querySelectorAll<HTMLElement>("[data-hue]")
      );
      for (const el of hueElements) {
        const attr = el.getAttribute("data-hue");
        if (attr === null || !isHue(attr)) continue;
        const hue: Hue = attr;
        el.addEventListener("pointerenter", () => applyHueOverride(hue));
        el.addEventListener("pointerleave", clearHueOverride);
        el.addEventListener("focusin", () => applyHueOverride(hue));
        el.addEventListener("focusout", clearHueOverride);
      }
    </script>
  </body>
</html>
