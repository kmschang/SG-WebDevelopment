{
  email admin@sonnazgroup.com
}

sonnazgroup.com, www.sonnazgroup.com, sonnazgroup.app, www.sonnazgroup.app, sonnazgroup.net, www.sonnazgroup.net, sonnazgroup.pro, www.sonnazgroup.pro {
  reverse_proxy sonnaz-site-prod:80
}

staging.sonnazgroup.com, staging.sonnazgroup.app, staging.sonnazgroup.net, staging.sonnazgroup.pro {
  basicauth {
    # Generate with: caddy hash-password
    uat-user CHANGE_ME_HASH
  }

  reverse_proxy sonnaz-site-staging:80
}

